<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- 标题栏 -->
        <LinearLayout
            android:id="@+id/title_bar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="#16213E">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/title_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="屏幕适配与设备配置"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 设备信息卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/device_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#1E2832">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前设备信息"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/device_info_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="正在检测..."
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 设备预设选择 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:text="选择设备预设"
            android:textSize="14sp"
            android:textColor="#888888" />

        <Spinner
            android:id="@+id/preset_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_spinner"
            android:padding="12dp" />

        <!-- 布局模式选择 -->
        <Button
            android:id="@+id/btn_layout_mode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:text="布局模式选择"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_outline" />

        <!-- 横竖屏切换 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="@drawable/bg_item_row">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="横屏模式"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />

            <ToggleButton
                android:id="@+id/screen_orientation_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textOn="横屏"
                android:textOff="竖屏" />

        </LinearLayout>

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btn_apply_preset"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="应用所选预设"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_primary" />

            <Button
                android:id="@+id/btn_auto_detect"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="自动检测并配置"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_secondary" />

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="重置为默认"
                android:textSize="14sp"
                android:textColor="#AAAAAA"
                android:background="@drawable/bg_btn_text" />

        </LinearLayout>

        <!-- 设备预设说明 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#16213E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设备预设说明"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="• 7寸车机：适用于1024x600分辨率\n• 10寸车机：适用于1280x800分辨率\n• 12寸车机：适用于1920x1200分辨率\n• 特斯拉风格：超宽屏极简设计\n• 竖屏车机：适用于竖屏安装的车机\n• 手机兼容：适用于手机竖屏使用"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
