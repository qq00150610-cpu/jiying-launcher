<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <!-- 壁纸背景 -->
    <ImageView
        android:id="@+id/wallpaper_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/default_wallpaper" />

    <!-- 左上角智能助理按钮 -->
    <ImageButton
        android:id="@+id/assistant_button"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_margin="24dp"
        android:background="@drawable/bg_circle_button"
        android:src="@drawable/ic_mic"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:contentDescription="智能助理" />

    <!-- 右上角时间日期区域 -->
    <LinearLayout
        android:id="@+id/time_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:orientation="vertical"
        android:gravity="end"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/date_time_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textSize="36sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/date_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2024年01月01日 周一"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- 快捷插件区域 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/quick_panel_card"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/assistant_button"
        android:layout_centerVertical="true"
        android:layout_marginStart="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/card_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 导航插件 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/navigation_card"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/nav_card_background"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_navigation"
                        android:scaleType="centerInside" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="导航"
                            android:textSize="18sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/nav_app_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="高德地图"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/text_hint" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 音乐插件 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/music_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/music_card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_music"
                            android:scaleType="centerInside" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/music_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="暂无播放"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/music_artist"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="点击播放"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:maxLines="1"
                                android:ellipsize="end" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 音乐控制按钮 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageButton
                            android:id="@+id/music_prev"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_button_small"
                            android:src="@drawable/ic_skip_previous"
                            android:scaleType="centerInside"
                            android:padding="8dp"
                            android:contentDescription="上一首" />

                        <ImageButton
                            android:id="@+id/music_play_pause"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="@drawable/bg_circle_button_primary"
                            android:src="@drawable/ic_play"
                            android:scaleType="centerInside"
                            android:padding="12dp"
                            android:contentDescription="播放/暂停" />

                        <ImageButton
                            android:id="@+id/music_next"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_button_small"
                            android:src="@drawable/ic_skip_next"
                            android:scaleType="centerInside"
                            android:padding="8dp"
                            android:contentDescription="下一首" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 应用网格区域 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/app_grid_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toEndOf="@id/quick_panel_card"
        android:layout_above="@id/bottom_navigation"
        android:layout_below="@id/time_container"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="24dp"
        android:clipToPadding="false" />

    <!-- 底部导航栏 -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/nav_bar_background"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/home_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_nav_button"
            android:src="@drawable/ic_home"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="首页" />

        <ImageButton
            android:id="@+id/wallpaper_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_nav_button"
            android:src="@drawable/ic_wallpaper"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="壁纸" />

        <ImageButton
            android:id="@+id/apps_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_nav_button"
            android:src="@drawable/ic_apps"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="应用" />

        <ImageButton
            android:id="@+id/service_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_nav_button"
            android:src="@drawable/ic_service"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="服务" />

        <ImageButton
            android:id="@+id/settings_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_nav_button"
            android:src="@drawable/ic_settings"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="设置" />

        <ImageButton
            android:id="@+id/theme_switch_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_nav_button"
            android:src="@drawable/ic_theme"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="切换主题" />
    </LinearLayout>

    <!-- 控制中心遮罩层 -->
    <RelativeLayout
        android:id="@+id/control_center_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <!-- 控制中心面板 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/control_panel_card"
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_margin="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="@color/control_panel_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- 标题栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="控制中心"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/close_control_center"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_button_small"
                        android:src="@drawable/ic_close"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        android:contentDescription="关闭" />
                </LinearLayout>

                <!-- 亮度调节 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="屏幕亮度"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <SeekBar
                    android:id="@+id/brightness_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="255"
                    android:progress="128"
                    android:layout_marginBottom="16dp" />

                <!-- 音量调节 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="媒体音量"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <SeekBar
                    android:id="@+id/volume_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="15"
                    android:progress="8"
                    android:layout_marginBottom="24dp" />

                <!-- 快捷开关 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- WiFi -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_wifi"
                            android:tint="@color/primary_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WiFi"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="4dp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/wifi_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- 蓝牙 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_bluetooth"
                            android:tint="@color/primary_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="蓝牙"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="4dp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/bluetooth_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- 夜间模式 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_night_mode"
                            android:tint="@color/primary_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="夜间模式"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="4dp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/night_mode_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

</RelativeLayout>
