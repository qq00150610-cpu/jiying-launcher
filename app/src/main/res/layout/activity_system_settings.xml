<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E14">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="系统设置"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- 设置列表 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="8dp">

            <!-- 悬浮球 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="?android:attr/selectableItemBackground">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_floating_ball"
                    android:tint="#00D9A5" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="悬浮球"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/floating_ball_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="#4D00D9A5"
                    app:thumbTint="#00D9A5"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />
            </LinearLayout>

            <!-- 悬浮球设置 -->
            <include layout="@layout/item_setting_arrow"
                android:id="@+id/floating_ball_settings" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="20dp"
                android:background="#1E2832" />

            <!-- WiFi设置 -->
            <include layout="@layout/item_setting_wifi"
                android:id="@+id/wifi_settings" />

            <!-- 蓝牙设置 -->
            <include layout="@layout/item_setting_bluetooth"
                android:id="@+id/bluetooth_settings" />

            <!-- 显示设置 -->
            <include layout="@layout/item_setting_display"
                android:id="@+id/display_settings" />

            <!-- 声音设置 -->
            <include layout="@layout/item_setting_sound"
                android:id="@+id/sound_settings" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="20dp"
                android:background="#1E2832" />

            <!-- 应用管理 -->
            <include layout="@layout/item_setting_app"
                android:id="@+id/app_management" />

            <!-- 存储设置 -->
            <include layout="@layout/item_setting_storage"
                android:id="@+id/storage_settings" />

            <!-- 位置设置 -->
            <include layout="@layout/item_setting_location"
                android:id="@+id/location_settings" />

            <!-- 文件管理 -->
            <include layout="@layout/item_setting_file"
                android:id="@+id/file_management" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="20dp"
                android:background="#1E2832" />

            <!-- 所有设置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="?android:attr/selectableItemBackground"
                android:id="@+id/all_settings">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="所有设置"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="#666666" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
